  "cards": [
    {
      "id": "mn-emergency",
      "front": "应急基金存多少?",
      "back": "通常 3-6 个月开支,随时可取。"
    },
    {
      "id": "mn-compound",
      "front": "为何越早越好?",
      "back": "复利让利息再生利息——越早的钱滚得越久。"
    },
    {
      "id": "mn-diversify",
      "front": "为何分散投资?",
      "back": "分散到多种资产,单个暴跌损失有限。"
    },
    {
      "id": "mn-debt",
      "front": "先还债还是投资?",
      "back": "通常先还高息债——利率高过多数投资收益。"
    },
    {
      "id": "mn-payself",
      "front": "\"先支付自己\"?",
      "back": "发薪日先自动存,免得先花掉。"
    },
    {
      "id": "mn-503020",
      "front": "50/30/20 法则?",
      "back": "约 50% 必需、30% 想要、20% 储蓄/还债。"
    },
    {
      "id": "mn-fees",
      "front": "手续费为何关键?",
      "back": "费用反向复利;每年 1% 几十年能吃掉一大块。"
    },
    {
      "id": "mn-inflation",
      "front": "通胀对现金?",
      "back": "悄悄削弱购买力——闲钱真实价值缩水。"
    },
    {
      "id": "mn-creep",
      "front": "生活方式膨胀?",
      "back": "收入涨花销也涨;每次加薪先存一部分。"
    },
    {
      "id": "mn-credit",
      "front": "良好信用的关键?",
      "back": "按时还、欠款占额度比例低。"
    },
    {
      "id": "mn-rule72",
      "front": "72 法则?",
      "back": "72 ÷ 年化收益 ≈ 翻倍年数(如 8% → 约 9 年)。"
    },
    {
      "id": "mn-dca",
      "front": "定投(成本平均法)?",
      "back": "按固定节奏投固定金额,摊平价格波动。"
    },
    {
      "id": "mn-horizon",
      "front": "风险怎么匹配时间?",
      "back": "近期要用的钱→稳;多年后才用的→可担更多风险。"
    },
    {
      "id": "mn-buyhold",
      "front": "择时 vs 长期持有?",
      "back": "长期在场通常胜过精准择时——长跑里持有者赢。"
    },
    {
      "id": "mn-networth",
      "front": "看收入还是净资产?",
      "back": "净资产(资产−负债)才反映真进展;只看收入会误导。"
    },
    {
      "id": "mn-opportunity",
      "front": "机会成本?",
      "back": "花在这的每块钱/每小时就不能用在别处——权衡次优选择。"
    },
    {
      "id": "mn-gooddebt",
      "front": "好债 vs 坏债?",
      "back": "能增值/生钱的债可能划算;高息消费贷通常不划算。"
    },
    {
      "id": "mn-insurance",
      "front": "保险该保什么?",
      "back": "大额、低频、扛不住的风险——不是你能自付的小开销。"
    },
    {
      "id": "mn-sinking",
      "front": "专项储蓄(sinking fund)?",
      "back": "为已知的将来开销(修车、送礼)每月攒点,到时不慌。"
    },
    {
      "id": "mn-24hr",
      "front": "怎么忍住冲动消费?",
      "back": "大额非必需品先等 24 小时(或更久)再决定。"
    },
    {
      "id": "mn-autopay",
      "front": "为何自动缴费?",
      "back": "自动扣款免逾期费和征信受损;留点余额即可。"
    },
    {
      "id": "mn-taxadv",
      "front": "为何用税优账户?",
      "back": "递延或免税的增长比应税账户滚得更快。"
    },
    {
      "id": "mn-liquidity",
      "front": "为何留点流动资金?",
      "back": "钱全锁死,急用时被迫做坏决定;留个现金垫。"
    }
  ]
}