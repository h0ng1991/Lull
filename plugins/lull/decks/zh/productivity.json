{
  "category": "productivity",
  "name": "Productivity",
  "cards": [
    {
      "id": "pr-2min",
      "front": "两分钟法则?",
      "back": "两分钟内能做完就立刻做——记下来比做掉还费劲。"
    },
    {
      "id": "pr-eisenhower",
      "front": "艾森豪威尔矩阵?",
      "back": "按紧急×重要分:做、排期、委派、删。"
    },
    {
      "id": "pr-pomodoro",
      "front": "番茄工作法?",
      "back": "25 分钟专注 + 5 分钟休息;短冲刺对抗拖延。"
    },
    {
      "id": "pr-start-small",
      "front": "对抗\"开不了头\"?",
      "back": "把第一步缩到不可能失败(\"只打开文件\")。"
    },
    {
      "id": "pr-timebox",
      "front": "时间盒是什么?",
      "back": "给任务固定时段,到点就停——防完美主义和拖延。"
    },
    {
      "id": "pr-singletask",
      "front": "为什么单线程?",
      "back": "切换有隐藏的\"重新进入\"成本;一次一件更快。"
    },
    {
      "id": "pr-frog",
      "front": "\"先吃青蛙\"?",
      "back": "最先做最难最重要的事,趁意志力没耗光。"
    },
    {
      "id": "pr-parkinson",
      "front": "帕金森定律?",
      "back": "工作会膨胀填满给的时间;截止设紧点往往照样完成。"
    },
    {
      "id": "pr-review",
      "front": "为何每周回顾?",
      "back": "十分钟清收件箱、对目标、排下周,防跑偏。"
    },
    {
      "id": "pr-batch",
      "front": "任务批处理?",
      "back": "把同类事放一个时间块,减少来回切换。"
    },
    {
      "id": "pr-mit",
      "front": "MIT 方法?",
      "back": "每天早上选 1-3 件\"最重要的事\",先做完它们再说别的。"
    },
    {
      "id": "pr-ivylee",
      "front": "艾维·李方法?",
      "back": "每晚按优先级列出明天 6 件事;从上往下做。"
    },
    {
      "id": "pr-deepwork",
      "front": "深度工作是什么?",
      "back": "长时间无干扰地专注一件难事——真正的产出在这里。"
    },
    {
      "id": "pr-capture",
      "front": "为何用一个收集清单?",
      "back": "把所有待办丢进一个可信的地方,大脑就不用反复提醒你。"
    },
    {
      "id": "pr-energy",
      "front": "怎么用精力高峰?",
      "back": "把难的、创造性的活排在精力最旺时;杂务放在低谷。"
    },
    {
      "id": "pr-wip",
      "front": "为何限制在办事项?",
      "back": "先完成再开新的,减少切换,事情才真正做完。"
    },
    {
      "id": "pr-ifthen",
      "front": "执行意图是什么?",
      "back": "\"如果发生 X,我就做 Y\"的预案——提前决定胜过临场拼意志力。"
    },
    {
      "id": "pr-8020",
      "front": "帕累托(80/20)法则?",
      "back": "约 80% 的结果来自 20% 的努力——找出并守住那 20%。"
    },
    {
      "id": "pr-breaks",
      "front": "什么是好的休息?",
      "back": "真正的休息(走动、远望)恢复专注;刷手机不算。"
    },
    {
      "id": "pr-shutdown",
      "front": "为何要\"收工仪式\"?",
      "back": "一个明确的下班流程(回顾、排明天)让大脑安心休息。"
    },
    {
      "id": "pr-routinize",
      "front": "怎么对抗决策疲劳?",
      "back": "把重复的小决定(吃什么、穿什么)固定下来,把意志力留给要紧事。"
    },
    {
      "id": "pr-distraction",
      "front": "最简单的专注提升?",
      "back": "把手机放到看不见的地方——能看见就分心,哪怕静音。"
    },
    {
      "id": "pr-template",
      "front": "重复性工作怎么提速?",
      "back": "用模板和清单,别重复思考已经解决过的问题。"
    }
  ]
}