{
  "category": "psychology",
  "name": "Mind & Thinking",
  "cards": [
    {
      "id": "ps-sunkcost",
      "front": "沉没成本陷阱?",
      "back": "收不回的过去成本不该左右决定——只看往后值不值。"
    },
    {
      "id": "ps-dunning",
      "front": "邓宁-克鲁格效应?",
      "back": "能力低易高估自己;真懂的人更谨慎。"
    },
    {
      "id": "ps-confirmation",
      "front": "确认偏误?",
      "back": "爱看符合信念的证据,忽视相反的。"
    },
    {
      "id": "ps-anchoring",
      "front": "锚定效应?",
      "back": "先看到的数字带偏后续判断。"
    },
    {
      "id": "ps-loss",
      "front": "损失厌恶?",
      "back": "损失的痛约是同等收益之爽的两倍。"
    },
    {
      "id": "ps-availability",
      "front": "可得性启发?",
      "back": "用\"例子好不好想起\"判断概率,而非真实几率。"
    },
    {
      "id": "ps-spotlight",
      "front": "聚光灯效应?",
      "back": "高估别人对我们的关注度。"
    },
    {
      "id": "ps-attribution",
      "front": "基本归因错误?",
      "back": "别人出错怪人品,自己出错怪环境。"
    },
    {
      "id": "ps-presentbias",
      "front": "现时偏差?",
      "back": "高估眼前小奖励,低估以后的大奖励。"
    },
    {
      "id": "ps-mindset",
      "front": "成长 vs 固定型思维?",
      "back": "固定型:能力天生;成长型:能力靠努力长出来。"
    },
    {
      "id": "ps-zeigarnik",
      "front": "蔡格尼克效应?",
      "back": "未完成的任务一直在脑中盘旋;写下来能让它安静。"
    },
    {
      "id": "ps-framing",
      "front": "框架效应?",
      "back": "措辞影响选择:\"90% 瘦肉\"听着比\"10% 肥肉\"好。"
    },
    {
      "id": "ps-socialproof",
      "front": "社会认同?",
      "back": "不确定时我们模仿别人——\"销量第一\"就是用这个。"
    },
    {
      "id": "ps-halo",
      "front": "光环效应?",
      "back": "一个优点(如好看)让我们误以为其他无关优点也有。"
    },
    {
      "id": "ps-negativity",
      "front": "负面偏好?",
      "back": "坏事的冲击更大、记得更久,即便和好事同等大小。"
    },
    {
      "id": "ps-planning",
      "front": "计划谬误?",
      "back": "我们低估任务耗时;预估要留余量、参考过往。"
    },
    {
      "id": "ps-flow",
      "front": "心流是什么?",
      "back": "挑战与能力大致匹配时的深度投入——太易无聊,太难焦虑。"
    },
    {
      "id": "ps-habit",
      "front": "习惯回路?",
      "back": "线索→行为→奖励。改习惯:留住线索/奖励,替换中间的行为。"
    },
    {
      "id": "ps-reciprocity",
      "front": "互惠规范?",
      "back": "受了好处就想回报——所以免费试用能带动销售。"
    },
    {
      "id": "ps-dissonance",
      "front": "认知失调?",
      "back": "持有矛盾观念让人难受,于是我们找理由自圆其说。"
    },
    {
      "id": "ps-survivorship",
      "front": "幸存者偏差?",
      "back": "只看成功者、看不到失败者,结论被带偏。"
    },
    {
      "id": "ps-decoy",
      "front": "诱饵效应?",
      "back": "加一个定价更差的选项,把你推向商家想卖的那个。"
    },
    {
      "id": "ps-fresh-start",
      "front": "新起点效应?",
      "back": "周一、生日、新年会提升开新习惯的动力——善用它们。"
    }
  ]
}