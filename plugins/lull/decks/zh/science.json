    },
    {
      "id": "sc-ice",
      "front": "冰为何浮起?",
      "back": "水结冰膨胀,冰密度比水小。"
    },
    {
      "id": "sc-seasons",
      "front": "四季成因?",
      "back": "地轴倾斜,而非离太阳远近。"
    },
    {
      "id": "sc-orbit",
      "front": "月亮为何不掉?",
      "back": "它在\"掉\",但横向够快总错过地球——这就是轨道。"
    },
    {
      "id": "sc-metal",
      "front": "金属为何摸着更凉?",
      "back": "同温下它把手的热导走得更快。"
    },
    {
      "id": "sc-salt",
      "front": "海水为何咸?",
      "back": "河流把矿物带入海,蒸发后越积越浓。"
    },
    {
      "id": "sc-rainbow",
      "front": "彩虹怎么来的?",
      "back": "雨滴把阳光折射分色,以固定角度反射。"
    },
    {
      "id": "sc-vacuum-fall",
      "front": "重的东西掉得更快吗?",
      "back": "不——真空里羽毛和锤子同时落地;差别来自空气阻力。"
    },
    {
      "id": "sc-daynight",
      "front": "昼夜怎么来的?",
      "back": "地球自转,而非太阳绕我们转。"
    },
    {
      "id": "sc-moonphase",
      "front": "月相成因?",
      "back": "我们看到月球被照亮一面的多少——不是地球阴影。"
    },
    {
      "id": "sc-tides",
      "front": "潮汐成因?",
      "back": "月球引力拉动海水(太阳也有份)。"
    },
    {
      "id": "sc-space-sound",
      "front": "太空为何安静?",
      "back": "声音需要介质;太空接近真空,无法传播。"
    },
    {
      "id": "sc-sweat",
      "front": "出汗怎么降温?",
      "back": "水分蒸发带走皮肤的热。"
    },
    {
      "id": "sc-bread",
      "front": "面包为何发起来?",
      "back": "酵母吃糖产生 CO2 气泡,被面团困住。"
    },
    {
      "id": "sc-rust",
      "front": "铁锈是什么?",
      "back": "铁与氧气和水长期反应生成氧化铁。"
    },
    {
      "id": "sc-photosynthesis",
      "front": "光合作用是什么?",
      "back": "植物用阳光把 CO2 和水变成糖,放出氧气。"
    },
    {
      "id": "sc-static",
      "front": "静电为何\"啪\"一下?",
      "back": "积累的电子跳过去平衡你和物体间的电荷。"
    },
    {
      "id": "sc-mirage",
      "front": "公路上的海市蜃楼?",
      "back": "光穿过近地的热空气弯折,看着像反光的水洼。"
    },
    {
      "id": "sc-fever",
      "front": "为何会发烧?",
      "back": "升高体温帮免疫系统对抗感染——是一种防御。"
    },
    {
      "id": "sc-redblue-star",
      "front": "红星还是蓝星更热?",
      "back": "蓝星更热、红星更凉——颜色反映温度。"
    }
  ]
}