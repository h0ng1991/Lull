{
  "category": "writing",
  "name": "Writing & Comms",
  "cards": [
    {
      "id": "wr-bluf",
      "front": "写邮件/汇报开头先写什么?",
      "back": "先写结论或请求,再写理由。对方很忙,先给重点(BLUF)。"
    },
    {
      "id": "wr-sbi",
      "front": "怎么提反馈才到位?",
      "back": "用 SBI:情境+具体行为+影响。讲事实和影响,不评判人。"
    },
    {
      "id": "wr-active",
      "front": "为什么用主动语态?",
      "back": "点明了谁在做、也更短:\"我们发布了\" 优于 \"它被发布了\"。"
    },
    {
      "id": "wr-filler",
      "front": "快速精简文字?",
      "back": "删废话:\"为了能够\"→\"为了\"、\"由于…的原因\"→\"因为\"。"
    },
    {
      "id": "wr-subject",
      "front": "好的邮件主题?",
      "back": "具体可操作:\"周五前需确认 X\",而非\"一个小问题\"。"
    },
    {
      "id": "wr-oneask",
      "front": "一封邮件几个请求?",
      "back": "最好一个;多了易被只回一半。拆开或用编号列表。"
    },
    {
      "id": "wr-no",
      "front": "职场怎么礼貌拒绝?",
      "back": "先认可,明确拒绝,再给替代方案或取舍。"
    },
    {
      "id": "wr-notes",
      "front": "会议纪要记什么?",
      "back": "决策、负责人、带日期的下一步——不是逐字稿。"
    },
    {
      "id": "wr-aloud",
      "front": "简单的校对技巧?",
      "back": "读出声——耳朵能抓到拗口和漏字。"
    },
    {
      "id": "wr-tldr",
      "front": "消息很长怎么帮读者?",
      "back": "顶部加一行 TL;DR,写要点和需要的行动。"
    },
    {
      "id": "wr-pyramid",
      "front": "金字塔原理是什么?",
      "back": "先给结论,再把支撑点分组放在下面——自上而下,不是慢慢铺垫。"
    },
    {
      "id": "wr-concrete",
      "front": "具体 vs 抽象?",
      "back": "具体更有说服力:\"加载从 8 秒降到 2 秒\"胜过\"提升了性能\"。"
    },
    {
      "id": "wr-verbs",
      "front": "为什么用强动词?",
      "back": "\"决定\"胜过\"做出决定\"——动词+名词的累赘既弱又长。"
    },
    {
      "id": "wr-parallel",
      "front": "什么是排比/平行结构?",
      "back": "列表各项用同一语法形式(都用动词或都用名词),更易读。"
    },
    {
      "id": "wr-cta",
      "front": "清晰的行动号召?",
      "back": "明确做什么、何时前:\"周四 17 点前回复确认\"。"
    },
    {
      "id": "wr-scannable",
      "front": "怎么让文字可速读?",
      "back": "短段落、要点列表、关键处加粗——多数人先扫一遍。"
    },
    {
      "id": "wr-jargon",
      "front": "给混合读者写?",
      "back": "少用或解释术语;假设读者比你以为的更外行一点。"
    },
    {
      "id": "wr-sowhat",
      "front": "\"那又怎样\"测试?",
      "back": "每个观点后问\"那又怎样\";答不上来就删掉。"
    },
    {
      "id": "wr-short",
      "front": "为什么句子要短?",
      "back": "一句一个意思更好懂;长句在\"而且/但是\"处断开。"
    },
    {
      "id": "wr-positive",
      "front": "指令怎么写?",
      "back": "说\"该做什么\",别只说\"别做什么\"——正面表述更清楚。"
    },
    {
      "id": "wr-tone",
      "front": "语气怎么把握?",
      "back": "按读者和渠道调正式度;群聊 ≠ 给客户的邮件。"
    },
    {
      "id": "wr-editpass",
      "front": "边写边改好吗?",
      "back": "不好——先快速成稿,再单独修改。一起做会卡住。"
    },
    {
      "id": "wr-frontload",
      "front": "标题关键词放哪?",
      "back": "放最前:\"退款政策——30 天\"胜过\"关于退款的政策\"。"
    },
    {
      "id": "wr-numbers",
      "front": "空泛的说法怎么救?",
      "back": "加数字或例子:\"省时间\"→\"每周省约 2 小时\"。"
    }
  ]
}